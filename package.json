{
  "name": "mark-rover",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main/main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev.ts",
    "start": "electron .",
    "postinstall": "node ./scripts/ensure-electron.ts",
    "build": "pnpm build:renderer && pnpm build:electron",
    "build:renderer": "vite build",
    "build:electron": "node ./scripts/build-electron.ts",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "knip": "knip",
    "qa": "pnpm fmt:check && pnpm lint && pnpm knip && pnpm check && pnpm test",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.node.json && tsc -p tsconfig.test.json",
    "check": "pnpm typecheck && pnpm build",
    "bench": "node ./scripts/bench.ts",
    "test": "node ./scripts/corpus-smoke.ts",
    "table:threshold": "node ./scripts/table-threshold.ts",
    "test:electron": "node ./tests/electron-smoke.ts && node ./tests/localization-smoke.ts && node ./tests/mermaid-smoke.ts",
    "cdp:launch": "MARK_ROVER_CDP_PORT=9222 electron . -- tests/corpus/smoke.md",
    "package:mac": "pnpm build && node ./scripts/package-mac.ts"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tanstack/table-core": "^8.21.3",
    "electron": "^39.2.6",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "sanitize-html": "^2.17.0",
    "svelte": "^5.43.13",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.4",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.22",
    "esbuild": "^0.28.0",
    "knip": "^6.15.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.6",
    "svelte-check": "^4.5.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.1"
}
