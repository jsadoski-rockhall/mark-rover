{
  "name": "mark-rover",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main/main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "start": "electron .",
    "build": "pnpm build:renderer && pnpm build:electron",
    "build:renderer": "vite build",
    "build:electron": "node ./scripts/build-electron.mjs",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "knip": "knip",
    "qa": "pnpm fmt:check && pnpm lint && pnpm knip && pnpm check && pnpm test",
    "check": "node --check src/main/main.mjs && node --check src/main/render-worker.mjs && node --check src/preload/preload.cjs && node --check scripts/build-electron.mjs && node --check scripts/package-mac.mjs && node --check scripts/bench.mjs && node --check scripts/corpus-smoke.mjs && node --check scripts/table-threshold.mjs && node --check tests/electron-smoke.mjs && node --check tests/localization-smoke.mjs && pnpm build",
    "bench": "node ./scripts/bench.mjs",
    "test": "node ./scripts/corpus-smoke.mjs",
    "table:threshold": "node ./scripts/table-threshold.mjs",
    "test:electron": "node ./tests/electron-smoke.mjs && node ./tests/localization-smoke.mjs",
    "cdp:launch": "MARK_ROVER_CDP_PORT=9222 electron . -- tests/corpus/smoke.md",
    "package:mac": "pnpm build && node ./scripts/package-mac.mjs"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tanstack/table-core": "^8.21.3",
    "electron": "^39.2.6",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "sanitize-html": "^2.17.0",
    "svelte": "^5.43.13",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "autoprefixer": "^10.4.22",
    "esbuild": "^0.28.0",
    "knip": "^6.15.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.6"
  },
  "packageManager": "pnpm@11.5.1"
}
